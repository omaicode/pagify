{
  "module": {
    "key": "content",
    "name": "Content",
    "version": "1.0.0",
    "description": "Content management module UI contract"
  },
  "menus": [
    {
      "key": "content.dashboard",
      "label": "Content",
      "icon": "document-text",
      "route": "content.admin.dashboard",
      "order": 30,
      "group": "Content",
      "permission": "content.type.viewAny"
    },
    {
      "key": "content.types",
      "label": "Content types",
      "icon": "squares-plus",
      "route": "content.admin.types.index",
      "order": 31,
      "group": "Content",
      "permission": "content.type.viewAny"
    }
  ],
  "pages": [
    {
      "key": "content.types.index",
      "title": "Content types",
      "route": "content.admin.types.index",
      "layout": "admin.default",
      "permission": "content.type.viewAny",
      "breadcrumb": ["Content", "Types"]
    }
  ],
  "actions": [
    {
      "key": "content.types.create",
      "label": "Create content type",
      "route": "content.admin.types.create",
      "method": "GET",
      "surface": "page-header",
      "permission": "content.type.create"
    },
    {
      "key": "content.entries.delete",
      "label": "Delete entry",
      "route": "content.admin.entries.destroy",
      "method": "DELETE",
      "surface": "row-action",
      "permission": "content.entry.delete",
      "destructive": true,
      "confirm": true
    }
  ],
  "widgets": [
    {
      "key": "content.stats.total-types",
      "title": "Total content types",
      "type": "stat",
      "surface": "dashboard",
      "permission": "content.type.viewAny",
      "refresh_seconds": 300
    }
  ]
}
