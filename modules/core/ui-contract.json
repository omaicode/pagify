{
  "module": {
    "key": "core",
    "name": "Core",
    "version": "1.0.0",
    "description": "System backbone module"
  },
  "menus": [
    {
      "key": "core.dashboard",
      "label": "Dashboard",
      "icon": "home",
      "route": "core.admin.dashboard",
      "order": 10,
      "group": "Core",
      "permission": "core.site.view"
    },
    {
      "key": "core.audit.index",
      "label": "Audit logs",
      "icon": "clipboard-document-list",
      "route": "core.admin.audit.index",
      "order": 20,
      "group": "Core",
      "permission": "core.audit.view"
    },
    {
      "key": "core.tokens.index",
      "label": "API tokens",
      "icon": "key",
      "route": "core.admin.tokens.index",
      "order": 30,
      "group": "Core",
      "permission": "core.token.manage"
    },
    {
      "key": "core.modules.index",
      "label": "Modules",
      "icon": "squares-2x2",
      "route": "core.admin.modules.index",
      "order": 40,
      "group": "Core",
      "permission": "core.module.manage"
    }
  ],
  "pages": [
    {
      "key": "core.dashboard",
      "title": "Dashboard",
      "route": "core.admin.dashboard",
      "layout": "admin.default",
      "permission": "core.site.view",
      "breadcrumb": ["Core", "Dashboard"]
    }
  ],
  "actions": [
    {
      "key": "core.tokens.create",
      "label": "Create token",
      "route": "core.api.v1.admin.tokens.store",
      "method": "POST",
      "surface": "page-header",
      "permission": "core.token.manage"
    }
  ],
  "widgets": [
    {
      "key": "core.audit.recent",
      "title": "Recent audit activity",
      "type": "activity",
      "surface": "dashboard",
      "permission": "core.audit.view",
      "refresh_seconds": 300
    }
  ]
}
