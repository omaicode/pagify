{% set presets = [
    {'key': 'ocean', 'label': 'Ocean'},
    {'key': 'forest', 'label': 'Forest'},
    {'key': 'sunset', 'label': 'Sunset'},
] %}
<div class="flex items-center gap-2">
    <label for="theme-preset-select" class="sr-only">Theme preset</label>
    <select id="theme-preset-select" data-theme-preset-select class="theme-preset-select rounded-full border border-[var(--line-soft)] bg-[var(--surface-card)] px-3 py-1.5 text-xs font-bold uppercase tracking-[0.08em] text-[var(--text-main)]">
        {% for preset in presets %}
            <option value="{{ preset.key }}">{{ preset.label }}</option>
        {% endfor %}
    </select>
</div>
