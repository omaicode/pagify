{% set delay = delay|default('0s') %}
{% set section_class = section_class|default('mt-6 pf-panel pf-reveal p-6 sm:p-8') %}
<section class="{{ section_class }}" style="--delay: {{ delay }};">
    <div class="grid gap-6 lg:grid-cols-[1fr,auto] lg:items-center">
        <div>
            <h2 class="pf-heading text-2xl font-extrabold">{{ title }}</h2>
            <p class="mt-2 text-sm leading-7 text-[var(--text-soft)] sm:text-base">{{ description }}</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <a class="pf-cta-btn pf-focusable" href="{{ primary_href }}">{{ primary_label }}</a>
            {% if secondary_href is defined and secondary_label is defined %}
                <a class="pf-cta-btn pf-cta-btn--ghost pf-focusable" href="{{ secondary_href }}">{{ secondary_label }}</a>
            {% endif %}
        </div>
    </div>
</section>
