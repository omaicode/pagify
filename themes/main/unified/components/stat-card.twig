{% set delay = delay|default('0s') %}
<article class="pf-panel pf-reveal p-5" style="--delay: {{ delay }};">
    <p class="text-sm font-semibold uppercase tracking-[0.08em] text-[var(--text-soft)]">{{ label }}</p>
    <p class="pf-heading mt-2 text-3xl font-extrabold">{{ value }}</p>
    <p class="mt-2 text-sm text-[var(--text-soft)]">{{ description }}</p>
</article>
