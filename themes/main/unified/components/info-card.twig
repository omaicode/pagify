{% set card_class = card_class|default('rounded-2xl border border-[var(--line-soft)] bg-white p-5') %}
{% set title_class = title_class|default('pf-heading text-xl font-bold') %}
{% set body_class = body_class|default('mt-2 text-sm leading-7 text-[var(--text-soft)]') %}
{% set delay = delay|default('0s') %}

<article class="{{ card_class }} pf-reveal" style="--delay: {{ delay }};">
    {% if overline is defined and overline|trim != '' %}
        <p class="text-xs font-bold uppercase tracking-[0.08em] text-[var(--brand-700)]">{{ overline }}</p>
    {% endif %}
    <h2 class="{{ title_class }}">{{ title }}</h2>
    <p class="{{ body_class }}">{{ description }}</p>
</article>
