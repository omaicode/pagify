<!doctype html>
<html lang="{{ locale|default('en')|replace({'_': '-'}) }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset_url('css/main.css') }}">
    <script defer src="{{ asset_url('js/theme-switcher.js') }}"></script>
    {{ head|raw }}
</head>
<body class="unified-body bg-[var(--surface-bg)] text-[var(--text-main)] antialiased" data-theme="unified" data-color-preset="ocean">
    <div class="absolute inset-x-0 top-0 -z-10 h-[360px] bg-[radial-gradient(circle_at_18%_18%,var(--bg-blob-1)_0,transparent_50%),radial-gradient(circle_at_84%_12%,var(--bg-blob-2)_0,transparent_40%),linear-gradient(180deg,var(--bg-start),var(--bg-end))]"></div>

    <header class="mx-auto w-full max-w-6xl px-4 pt-6 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-[var(--line-soft)] bg-[var(--surface-card)]/95 px-4 py-3 shadow-[0_14px_50px_-24px_var(--shadow-color)] backdrop-blur sm:px-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <a href="{{ page_url('home') }}" class="font-display text-lg font-extrabold tracking-tight text-[var(--brand-700)]">Pagify CMS</a>
                <nav class="flex flex-wrap items-center gap-3 text-sm font-semibold text-[var(--text-soft)]">
                    <a class="rounded-full px-3 py-1.5 transition hover:bg-[var(--surface-muted)] hover:text-[var(--text-main)]" href="{{ page_url('home') }}">Home</a>
                    <a class="rounded-full px-3 py-1.5 transition hover:bg-[var(--surface-muted)] hover:text-[var(--text-main)]" href="{{ page_url('about') }}">About</a>
                    <a class="rounded-full px-3 py-1.5 transition hover:bg-[var(--surface-muted)] hover:text-[var(--text-main)]" href="{{ page_url('features') }}">Features</a>
                    <a class="rounded-full px-3 py-1.5 transition hover:bg-[var(--surface-muted)] hover:text-[var(--text-main)]" href="{{ page_url('docs') }}">Docs</a>
                    <a class="rounded-full px-3 py-1.5 transition hover:bg-[var(--surface-muted)] hover:text-[var(--text-main)]" href="{{ page_url('contact') }}">Contact</a>
                </nav>
                <div class="flex items-center gap-2 rounded-full bg-[var(--surface-muted)] p-1">
                    <button type="button" data-theme-preset="ocean" class="theme-toggle-btn rounded-full px-3 py-1.5 text-xs font-bold uppercase tracking-[0.08em]" aria-label="Switch to Ocean theme">Ocean</button>
                    <button type="button" data-theme-preset="forest" class="theme-toggle-btn rounded-full px-3 py-1.5 text-xs font-bold uppercase tracking-[0.08em]" aria-label="Switch to Forest theme">Forest</button>
                    <button type="button" data-theme-preset="sunset" class="theme-toggle-btn rounded-full px-3 py-1.5 text-xs font-bold uppercase tracking-[0.08em]" aria-label="Switch to Sunset theme">Sunset</button>
                </div>
            </div>
        </div>
    </header>

    <main class="mx-auto mt-6 w-full max-w-6xl px-4 pb-14 sm:px-6 lg:px-8">
        {{ content|raw }}
    </main>

    <footer class="mx-auto mb-10 w-full max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-[var(--line-soft)] bg-[var(--surface-card)] px-6 py-5 text-sm text-[var(--text-soft)] shadow-[0_14px_40px_-28px_var(--shadow-color)]">
            <p class="font-semibold text-[var(--text-main)]">Unified Theme</p>
            <p class="mt-1">Default multipurpose experience for introducing Pagify CMS.</p>
        </div>
    </footer>

    <div class="sr-only" aria-live="polite" id="theme-status"></div>
</body>
</html>
