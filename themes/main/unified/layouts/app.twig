<!doctype html>
<html lang="{{ locale|default('en')|replace({'_': '-'}) }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset_url('css/main.css') }}">
    <script defer src="{{ asset_url('js/theme-switcher.js') }}"></script>
    {{ head|raw }}
</head>
<body class="unified-body bg-[var(--surface-bg)] text-[var(--text-main)] antialiased" data-theme="unified" data-color-preset="ocean">
    {% include 'components/site-header.twig' %}

    <main class="mx-auto mt-6 w-full max-w-6xl px-4 pb-14 sm:px-6 lg:px-8">
        {% block body %}
            {{ content|raw }}
        {% endblock %}
    </main>

    {% include 'components/site-footer.twig' %}

    <div class="sr-only" aria-live="polite" id="theme-status"></div>
</body>
</html>
