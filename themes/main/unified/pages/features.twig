{% extends 'layouts/app.twig' %}

{% block body %}
<section class="pf-panel pf-reveal p-6 sm:p-10" style="--delay: 0.02s;">
    <span class="pf-badge">Features</span>
    <h1 class="pf-heading mt-4 text-3xl font-extrabold sm:text-4xl">Everything needed for modern CMS operations</h1>
    <p class="mt-4 max-w-3xl text-base leading-8 text-[var(--text-soft)]">Unified ships with common building blocks so teams can launch fast while keeping architecture boundaries clean.</p>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
        {% include 'components/info-card.twig' with {
            overline: 'Builder',
            title: 'Visual Page Builder',
            description: 'Create and publish landing pages with revision history and snapshot rendering.',
            delay: '0.1s'
        } only %}
        {% include 'components/info-card.twig' with {
            overline: 'Content',
            title: 'Schema-driven Content',
            description: 'Model content types with field-level controls and publish workflow.',
            delay: '0.14s'
        } only %}
        {% include 'components/info-card.twig' with {
            overline: 'Security',
            title: 'Secure by default',
            description: 'Role-based permissions, policy enforcement, and audit logs across admin actions.',
            delay: '0.18s'
        } only %}
        {% include 'components/info-card.twig' with {
            overline: 'Scale',
            title: 'Multi-site aware',
            description: 'Site isolation and locale-aware middleware for tenant-safe operations.',
            delay: '0.22s'
        } only %}
    </div>
</section>

{% include 'components/cta-panel.twig' with {
    title: 'Need a tailored implementation path?',
    description: 'Use Unified as a baseline and map the next iterations around your content model, publishing workflow, and deployment constraints.',
    primary_label: 'Open docs',
    primary_href: site_url('docs'),
    section_class: 'mt-6 pf-panel pf-reveal p-6 sm:p-8',
    delay: '0.26s'
} only %}
{% endblock %}
