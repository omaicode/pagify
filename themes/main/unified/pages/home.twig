{% extends 'layouts/app.twig' %}

{% block body %}
{% if content is defined and content|trim != '' %}
{{ content|raw }}
{% else %}
<section class="pf-panel pf-reveal overflow-hidden p-6 sm:p-10" style="--delay: 0.02s;">
    <div class="grid gap-8 lg:grid-cols-[1.15fr,0.85fr] lg:items-center">
        <div>
            <span class="pf-badge">Pagify Unified</span>
            <h1 class="pf-heading mt-4 text-4xl font-extrabold leading-tight sm:text-5xl">Build complete CMS websites in minutes</h1>
            <p class="mt-4 text-base leading-8 text-[var(--text-soft)] sm:text-lg">Pagify combines modular architecture, visual page editing, content modeling, and multi-site control into one clean Laravel-powered CMS.</p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
                <a class="pf-cta-btn pf-focusable" href="{{ site_url('features') }}">Explore features</a>
                <a class="pf-cta-btn pf-cta-btn--ghost pf-focusable" href="{{ site_url('docs') }}">Read docs</a>
            </div>
        </div>
        <div class="pf-panel bg-[var(--surface-muted)] p-5 pf-reveal" style="--delay: 0.12s;">
            <h2 class="pf-heading text-xl font-bold">Why teams choose Pagify</h2>
            <ul class="mt-4 grid gap-3 text-sm text-[var(--text-soft)] sm:text-base">
                <li class="rounded-xl border border-[var(--line-soft)] bg-white px-4 py-3">Modular domains: core, content, media, page-builder, updater.</li>
                <li class="rounded-xl border border-[var(--line-soft)] bg-white px-4 py-3">Ready for production with permissions, audit logs, and queue-friendly workflows.</li>
                <li class="rounded-xl border border-[var(--line-soft)] bg-white px-4 py-3">Theme system with Twig sandbox and safe fallback rendering.</li>
            </ul>
        </div>
    </div>
</section>

<section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {% include 'components/stat-card.twig' with {
        label: 'Pages',
        value: '5',
        description: 'Ready-to-use Twig pages in the Unified theme.',
        delay: '0.06s'
    } only %}
    {% include 'components/stat-card.twig' with {
        label: 'Color presets',
        value: '3',
        description: 'Ocean, Forest, Sunset with instant switch.',
        delay: '0.1s'
    } only %}
    {% include 'components/stat-card.twig' with {
        label: 'Responsive',
        value: '100%',
        description: 'Mobile-first sections and adaptive cards.',
        delay: '0.14s'
    } only %}
    {% include 'components/stat-card.twig' with {
        label: 'Powered by',
        value: 'Laravel 12',
        description: 'Modern PHP stack with strong DX.',
        delay: '0.18s'
    } only %}
</section>

{% include 'components/cta-panel.twig' with {
    title: 'Ready to launch your first site?',
    description: 'Start with Unified defaults, then customize Twig sections or connect dynamic content from the docs content type.',
    primary_label: 'Talk to us',
    primary_href: site_url('contact'),
    delay: '0.22s'
} only %}
{% endif %}
{% endblock %}
