{% extends 'layouts/app.twig' %}

{% block body %}
<section class="pf-panel pf-reveal p-6 sm:p-10" style="--delay: 0.02s;">
    <span class="pf-badge">Documentation</span>
    <h1 class="pf-heading mt-4 text-3xl font-extrabold sm:text-4xl">Start building with Pagify docs</h1>
    <p class="mt-4 max-w-3xl text-base leading-8 text-[var(--text-soft)]">Use this default page as a direct Twig entry. You can publish documentation pages through your active theme and route stack.</p>
    <div class="mt-6 rounded-2xl border border-[var(--line-soft)] bg-[var(--surface-muted)] p-5 pf-reveal" style="--delay: 0.1s;">
        <p class="text-sm text-[var(--text-soft)]">Example docs URL</p>
        <p class="mt-2 break-all font-mono text-sm font-semibold text-[var(--text-main)]">{{ site_url('docs') }}</p>
    </div>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
        {% include 'components/info-card.twig' with {
            title: 'Quickstart',
            description: 'Install, configure site context, and publish your first page.',
            title_class: 'pf-heading text-lg font-bold',
            delay: '0.14s'
        } only %}
        {% include 'components/info-card.twig' with {
            title: 'Architecture',
            description: 'Understand modules, contracts, and runtime boundaries.',
            title_class: 'pf-heading text-lg font-bold',
            delay: '0.18s'
        } only %}
        {% include 'components/info-card.twig' with {
            title: 'Operations',
            description: 'Queue, publishing workflow, and production troubleshooting.',
            title_class: 'pf-heading text-lg font-bold',
            delay: '0.22s'
        } only %}
    </div>

    <div class="mt-6 rounded-2xl border border-[var(--line-soft)] bg-white p-5 pf-reveal" style="--delay: 0.26s;">
        <h2 class="pf-heading text-lg font-bold">First-week checklist</h2>
        <ul class="mt-3 grid gap-2 text-sm text-[var(--text-soft)]">
            <li>1. Configure site domain and confirm `site_url()` output.</li>
            <li>2. Verify docs page routing from your active frontend theme.</li>
            <li>3. Customize Unified pages and rebuild theme assets.</li>
        </ul>
        <div class="mt-4">
            {% include 'components/cta-panel.twig' with {
                title: 'Need help with implementation?',
                description: 'Use the docs as baseline, then request support for architecture review and rollout hardening.',
                primary_label: 'Explore capabilities',
                primary_href: site_url('features'),
                secondary_label: 'Ask for support',
                secondary_href: site_url('contact'),
                section_class: 'pf-panel border border-[var(--line-soft)] bg-[var(--surface-muted)] p-5',
                delay: '0s'
            } only %}
        </div>
    </div>
</section>
{% endblock %}
