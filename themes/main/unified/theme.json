{
  "slug": "unified",
  "name": "Unified",
  "version": "1.0.0",
  "description": "Multipurpose default theme for introducing Pagify CMS.",
  "author": "Pagify",
  "design": {
    "color_presets": [
      "ocean",
      "forest",
      "sunset"
    ],
    "default_preset": "ocean",
    "responsive": true,
    "style": "tailwind"
  },
  "render": {
    "engine": "twig"
  },
  "requires": {
    "php": ">=8.2",
    "laravel": "^12.0"
  },
  "supports": {
    "pagify": "^1.0"
  }
}
